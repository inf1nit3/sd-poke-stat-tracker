{
  "name": "sd-poke-stat-tracker",
  "version": "0.1.0",
  "description": "In-game party stat tracker for Pokémon Essentials fan games on Steam Deck",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "test": "echo \"No tests yet\" && exit 0",
    "decky": "python3 main.py --remote-debugging-port=9222"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "pokemon",
    "fan-game",
    "rpg-maker",
    "essentials",
    "stat-tracker"
  ],
  "author": "inf1nit3",
  "homepage": "https://github.com/inf1nit3/sd-poke-stat-tracker",
  "license": "MIT",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@decky/api",
        "@decky/manifest",
        "decky-frontend-lib",
        "typescript-transform-paths"
      ]
    }
  }
}
