{
  "name": "pokemon-overlay-plugin",
  "version": "0.1.0",
  "description": "In-game overlay for Pokémon Essentials fan games on Steam Deck",
  "scripts": {
    "build": "shx rm -rf dist && shx cp -r public dist && node build.js",
    "watch": "node build.js --watch",
    "test": "echo \"No tests\" && exit 0",
    "decky": "python3 main.py --remote-debugging-port=9222"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "pokemon",
    "fan-game",
    "rpg-maker",
    "essentials"
  ],
  "author": "scheisssewasser",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/webpack": "^5.28.5",
    "esbuild": "^0.19.11",
    "shx": "^0.3.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@decky/api",
        "@decky/manifest",
        "decky-frontend-lib",
        "typescript-transform-paths"
      ]
    }
  }
}
